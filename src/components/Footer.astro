          </a>
          <a href="#" target="_blank" class="social-link" title="Discord">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994.021-.041.001-.09-.041-.106a13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03z"/></svg>
          </a>
          <a href="#" target="_blank" class="social-link" title="Twitter">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
        </div>
      </div>

      <!-- Links -->
      <div class="footer-links-group">
        <h4 class="footer-group-title">Project</h4>
        <ul>
          <li><a href="#features">Features</a></li>
          <li><a href="#architecture">Architecture</a></li>
          <li><a href="#tools">Built-in Tools</a></li>
          <li><a href="#platforms">Platforms</a></li>
        </ul>
      </div>
      <div class="footer-links-group">
        <h4 class="footer-group-title">Resources</h4>
        <ul>
          <li><a href="#">Documentation</a></li>
          <li><a href="#">Installation Guide</a></li>
          <li><a href="#">Configuration</a></li>
          <li><a href="#">Changelog</a></li>
        </ul>
      </div>
      <div class="footer-links-group">
        <h4 class="footer-group-title">Community</h4>
        <ul>
          <li><a href="#">GitHub</a></li>
          <li><a href="#">Discord</a></li>
          <li><a href="#">Contributing</a></li>
          <li><a href="#">Bug Reports</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <div class="footer-bar"></div>
      <div class="footer-meta">
        <span>© 2026 Cyber Terminal. MIT License.</span>
        <span class="footer-built">
          Built with <span class="heart">♥</span> in C
        </span>
        <span class="footer-version">v1.0.0</span>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: 5rem 0 2rem;
    border-top: 1px solid rgba(0,245,255,0.1);
  }
  .footer-top {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 4rem;
    margin-bottom: 4rem;
  }
  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin-bottom: 1rem;
  }
  .footer-logo-text {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    color: var(--color-white);
  }
  .logo-accent { color: var(--color-cyan); }
  .footer-tagline {
    font-size: 0.85rem;
    color: var(--color-white-dim);
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }
  .footer-social {
    display: flex;
    gap: 0.75rem;
  }
  .social-link {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-white-dim);
    text-decoration: none;
    transition: all 0.3s ease;
  }
  .social-link:hover {
    border-color: var(--color-cyan);
    color: var(--color-cyan);
    background: rgba(0,245,255,0.06);
    box-shadow: 0 0 10px rgba(0,245,255,0.2);
  }

  .footer-group-title {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-white);
    margin-bottom: 1.2rem;
  }
  .footer-links-group ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .footer-links-group a {
    font-size: 0.85rem;
    color: var(--color-white-dim);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .footer-links-group a:hover { color: var(--color-cyan); }

  .footer-bar {
    height: 1px;
    background: rgba(255,255,255,0.06);
    margin-bottom: 1.5rem;
  }
  .footer-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-white-dim);
  }
  .heart { color: #ff2d55; }
  .footer-version {
    font-size: 0.65rem;
    padding: 0.2rem 0.6rem;
    border: 1px solid rgba(0,245,255,0.2);
    border-radius: 100px;
    color: var(--color-cyan);
  }

  @media (max-width: 900px) {
    .footer-top { grid-template-columns: 1fr 1fr; }
    .footer-brand { grid-column: 1 / -1; }
  }
  @media (max-width: 480px) {
    .footer-top { grid-template-columns: 1fr; }
  }
</style>
