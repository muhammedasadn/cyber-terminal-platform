---
<footer class="footer">
  <div class="container">
    <div class="footer-top">
      <!-- Brand -->
      <div class="footer-brand">
        <div class="footer-logo">
          <svg width="28" height="28" viewBox="0 0 32 32" fill="none">
            <rect x="2" y="2" width="28" height="28" rx="4" stroke="#00f5ff" stroke-width="1.5"/>
            <path d="M8 11l5 5-5 5" stroke="#39ff14" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <line x1="16" y1="21" x2="24" y2="21" stroke="#00f5ff" stroke-width="2" stroke-linecap="round"/>
          </svg>
          <span class="footer-logo-text">CYBER<span class="logo-accent">TERM</span></span>
        </div>
        <p class="footer-tagline">
          A professional, GPU-accelerated cross-platform terminal emulator written in C.
          Open source. MIT Licensed.
        </p>
        <div class="footer-social">
          <a href="https://github.com/muhammedasadn" target="_blank" class="social-link" title="GitHub">
