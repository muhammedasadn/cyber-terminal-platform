---
---
<section class="cta-section" id="cta">
  <!-- Matrix rain canvas -->
  <canvas id="matrix-canvas" class="matrix-canvas"></canvas>
  <div class="cta-overlay"></div>

  <div class="container cta-content">
    <div class="cta-inner" data-reveal>
      <p class="section-label cta-section-label">Open Source & Free</p>
      <h2 class="cta-title">
        Build the Future of<br/>
        <span class="cta-gradient">Terminal Emulation.</span>
      </h2>
      <p class="cta-desc">
        Cyber Terminal is open source, MIT licensed, and built for the community.
        Star the repo, fork it, contribute, or just use it. Zero cost. Forever.
      </p>

      <div class="cta-actions">
        <a href="https://github.com" target="_blank" class="btn-primary cta-btn-main gradient-border">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
          </svg>
          View on GitHub
        </a>
        <a href="#features" class="btn-secondary">
          Read the Docs
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>

      <!-- Build command -->
      <div class="cta-command">
        <span class="cmd-prompt">$</span>
        <span class="cmd-text">git clone https://github.com/cyberterm/cyberterm.git && cmake -B build && cmake --build build</span>
        <button class="cmd-copy" id="copy-cmd" title="Copy command">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
        </button>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section {
    min-height: 100vh;
    position: relative;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .matrix-canvas {
    position: absolute;
    inset: 0;
    z-index: 0;
    opacity: 0.35;
  }
  .cta-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: radial-gradient(ellipse 70% 60% at 50% 50%, rgba(2,2,9,0.3) 0%, rgba(2,2,9,0.9) 100%);
  }

  .cta-content {
    position: relative;
    z-index: 2;
    text-align: center;
  }
  .cta-inner {
    max-width: 720px;
    margin: 0 auto;
  }

  .cta-section-label {
    justify-content: center;
  }
  .cta-section-label::before { display: none; }

  .cta-title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    color: var(--color-white);
    margin-bottom: 1.5rem;
    line-height: 1.05;
  }
  .cta-gradient {
    background: linear-gradient(135deg, var(--color-cyan), var(--color-green));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    filter: drop-shadow(0 0 20px rgba(0,245,255,0.4));
  }
  .cta-desc {
    font-size: 1.1rem;
    color: var(--color-white-dim);
    line-height: 1.7;
    margin-bottom: 2.5rem;
  }

  .cta-actions {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }
  .cta-btn-main {
    font-size: 0.9rem;
    padding: 1rem 2.5rem;
  }

  .cta-command {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    background: rgba(0,0,0,0.6);
    border: 1px solid rgba(0,245,255,0.15);
    border-radius: 8px;
    padding: 0.9rem 1.2rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-white-dim);
    max-width: 90%;
    overflow: hidden;
  }
  .cmd-prompt {
    color: var(--color-green);
    font-weight: 700;
    flex-shrink: 0;
  }
  .cmd-text {
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: var(--color-cyan);
  }
  .cmd-copy {
    flex-shrink: 0;
    background: none;
    border: none;
    color: var(--color-white-dim);
    cursor: pointer;
    padding: 4px;
    border-radius: 4px;
    transition: color 0.2s ease, background 0.2s ease;
  }
  .cmd-copy:hover {
    color: var(--color-cyan);
    background: rgba(0,245,255,0.1);
  }
</style>

<script>
// Matrix Rain Animation
const canvas = document.getElementById('matrix-canvas') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;

function resize() {
  canvas.width = window.innerWidth;
  canvas.height = window.innerHeight;
}
resize();
window.addEventListener('resize', resize);

const chars = '01アイウエオカキクケコ#$%@!&ABCDEF{}[]<>?=+cyberterm';
const charArr = chars.split('');
const fontSize = 13;
let columns = Math.floor(canvas.width / fontSize);
let drops: number[] = Array(columns).fill(1);

function drawMatrix() {
  ctx.fillStyle = 'rgba(2, 2, 9, 0.06)';
  ctx.fillRect(0, 0, canvas.width, canvas.height);
  
  ctx.font = `${fontSize}px 'JetBrains Mono', monospace`;
  
  drops.forEach((y, x) => {
    const char = charArr[Math.floor(Math.random() * charArr.length)];
    const isGreen = Math.random() > 0.9;
    ctx.fillStyle = isGreen ? '#39ff14' : `rgba(0, 245, 255, ${0.2 + Math.random() * 0.5})`;
    ctx.fillText(char, x * fontSize, y * fontSize);
    
    if (y * fontSize > canvas.height && Math.random() > 0.975) {
      drops[x] = 0;
    }
    drops[x]++;
  });
}

setInterval(drawMatrix, 45);

// Handle resize
window.addEventListener('resize', () => {
  resize();
  columns = Math.floor(canvas.width / fontSize);
  drops = Array(columns).fill(1);
});

// Copy command
document.getElementById('copy-cmd')?.addEventListener('click', () => {
  const cmd = 'git clone https://github.com/cyberterm/cyberterm.git && cmake -B build && cmake --build build';
  navigator.clipboard.writeText(cmd).then(() => {
    const btn = document.getElementById('copy-cmd')!;
    btn.style.color = '#39ff14';
    setTimeout(() => { btn.style.color = ''; }, 1500);
  });
});
</script>
