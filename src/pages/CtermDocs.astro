---
import CtermDocs from "../components/pages/CtermDocs.astro";

---

<style is:global>
/* Converted from src/components/cterm_docs.html */
  :root {
    --bg: #0d1117;
    --surface: #161b22;
    --surface2: #21262d;
    --border: #30363d;
    --text: #e6edf3;
    --muted: #8b949e;
    --accent: #58a6ff;
    --accent2: #3fb950;
    --accent3: #f78166;
    --accent4: #d2a8ff;
    --accent5: #ffa657;
    --code-bg: #0d1117;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.7;
    font-size: 15px;
  }

  /* ── Sidebar ── */
  .sidebar {
    position: fixed;
    top: 0; left: 0;
    width: 260px; height: 100vh;
    background: var(--surface);
    border-right: 1px solid var(--border);
    overflow-y: auto;
    z-index: 100;
    padding: 0 0 40px;
  }
  .sidebar-logo {
    padding: 24px 20px 20px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 12px;
  }
  .sidebar-logo h1 {
    font-size: 22px;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: -0.5px;
  }
  .sidebar-logo p {
    font-size: 12px;
    color: var(--muted);
    margin-top: 2px;
  }
  .sidebar nav a {
    display: block;
    padding: 7px 20px;
    color: var(--muted);
    text-decoration: none;
    font-size: 13.5px;
    transition: all 0.15s;
    border-left: 3px solid transparent;
  }
  .sidebar nav a:hover,
  .sidebar nav a.active {
    color: var(--accent);
    background: rgba(88,166,255,0.08);
    border-left-color: var(--accent);
  }
  .sidebar nav .section-label {
    padding: 16px 20px 4px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--muted);
  }
  .version-badge {
    display: inline-block;
    background: rgba(63,185,80,0.15);
    color: var(--accent2);
    font-size: 11px;
    padding: 2px 8px;
    border-radius: 12px;
    margin-left: 6px;
    font-weight: 600;
  }

  /* ── Main content ── */
  .main {
    margin-left: 260px;
    max-width: 900px;
    padding: 48px 60px;
  }

  /* ── Page sections ── */
  .page {
    min-height: 100vh;
    padding-bottom: 80px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 60px;
  }
  .page:last-child { border-bottom: none; }

  .page-header {
    margin-bottom: 40px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--border);
  }
  .page-number {
    font-size: 12px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 8px;
  }
  h2.page-title {
    font-size: 32px;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.5px;
    margin-bottom: 10px;
  }
  .page-subtitle {
    color: var(--muted);
    font-size: 16px;
  }

  /* ── Typography ── */
  h3 {
    font-size: 20px;
    font-weight: 600;
    color: var(--text);
    margin: 36px 0 14px;
  }
  h4 {
    font-size: 16px;
    font-weight: 600;
    color: var(--accent4);
    margin: 24px 0 10px;
  }
  p { margin-bottom: 16px; color: #c9d1d9; }

  /* ── Code ── */
  pre {
    background: var(--code-bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 20px;
    overflow-x: auto;
    margin: 20px 0;
    font-size: 13.5px;
    line-height: 1.6;
  }
  code {
    font-family: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace;
    font-size: 13px;
  }
  p code, li code {
    background: var(--surface2);
    padding: 2px 6px;
    border-radius: 4px;
    color: var(--accent3);
    font-size: 13px;
  }
  .kw  { color: #ff7b72; }
  .str { color: #a5d6ff; }
  .cmt { color: #8b949e; font-style: italic; }
  .fn  { color: #d2a8ff; }
  .num { color: #79c0ff; }
  .typ { color: #ffa657; }

  /* ── Tables ── */
  table {
    width: 100%;
    border-collapse: collapse;
    margin: 20px 0;
    font-size: 14px;
  }
  th {
    background: var(--surface2);
    padding: 10px 14px;
    text-align: left;
    font-weight: 600;
    font-size: 13px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border-bottom: 2px solid var(--border);
  }
  td {
    padding: 10px 14px;
    border-bottom: 1px solid var(--border);
    color: #c9d1d9;
  }
  tr:hover td { background: rgba(255,255,255,0.02); }
  td:first-child code { color: var(--accent); }

  /* ── Cards ── */
  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 16px;
    margin: 24px 0;
  }
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 20px;
    transition: border-color 0.2s;
  }
  .card:hover { border-color: var(--accent); }
  .card-icon {
    width: 36px; height: 36px;
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 18px;
    margin-bottom: 12px;
  }
  .card h4 { margin: 0 0 6px; color: var(--text); font-size: 15px; }
  .card p { font-size: 13px; color: var(--muted); margin: 0; }

  /* ── Callouts ── */
  .callout {
    border-radius: 8px;
    padding: 16px 20px;
    margin: 20px 0;
    font-size: 14px;
    border-left: 4px solid;
    display: flex;
    gap: 12px;
    align-items: flex-start;
  }
  .callout-icon { font-size: 18px; flex-shrink: 0; margin-top: 1px; }
  .callout-content { flex: 1; }
  .callout-content p { margin: 0; }
  .callout.info {
    background: rgba(88,166,255,0.08);
    border-color: var(--accent);
  }
  .callout.tip {
    background: rgba(63,185,80,0.08);
    border-color: var(--accent2);
  }
  .callout.warn {
    background: rgba(255,166,87,0.08);
    border-color: var(--accent5);
  }

  /* ── Architecture diagram ── */
  .arch-diagram {
    background: var(--code-bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 24px;
    margin: 20px 0;
    font-family: monospace;
    font-size: 13px;
    line-height: 1.8;
    color: #8b949e;
    white-space: pre;
    overflow-x: auto;
  }
  .arch-diagram .box { color: var(--accent); }
  .arch-diagram .arrow { color: var(--accent5); }
  .arch-diagram .label { color: var(--accent2); }

  /* ── Shortcut key ── */
  kbd {
    display: inline-block;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-bottom: 3px solid var(--border);
    border-radius: 5px;
    padding: 2px 8px;
    font-family: monospace;
    font-size: 12px;
    color: var(--text);
    margin: 0 2px;
  }

  /* ── Module timeline ── */
  .timeline {
    position: relative;
    padding-left: 28px;
    margin: 24px 0;
  }
  .timeline::before {
    content: '';
    position: absolute;
    left: 7px; top: 8px; bottom: 8px;
    width: 2px;
    background: var(--border);
  }
  .timeline-item {
    position: relative;
    margin-bottom: 20px;
    padding: 14px 18px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
  }
  .timeline-item::before {
    content: '';
    position: absolute;
    left: -21px; top: 18px;
    width: 12px; height: 12px;
    border-radius: 50%;
    background: var(--accent);
    border: 2px solid var(--bg);
  }
  .timeline-item h4 { margin: 0 0 4px; color: var(--accent); }
  .timeline-item p { margin: 0; font-size: 13px; color: var(--muted); }

  /* ── File tree ── */
  .file-tree {
    background: var(--code-bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 20px;
    font-family: monospace;
    font-size: 13px;
    line-height: 1.9;
    margin: 20px 0;
  }
  .file-tree .dir { color: var(--accent); font-weight: 600; }
  .file-tree .file { color: #c9d1d9; }
  .file-tree .comment { color: var(--muted); }
  .file-tree .indent { color: var(--border); }

  /* ── Hero section ── */
  .hero {
    background: linear-gradient(135deg, #0d1117 0%, #161b22 100%);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 40px;
    margin-bottom: 40px;
    text-align: center;
  }
  .hero h1 {
    font-size: 48px;
    font-weight: 800;
    background: linear-gradient(135deg, #58a6ff, #3fb950);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 12px;
    letter-spacing: -1px;
  }
  .hero p {
    font-size: 18px;
    color: var(--muted);
    max-width: 500px;
    margin: 0 auto 24px;
  }
  .hero-badges {
    display: flex;
    gap: 10px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .badge {
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 13px;
    font-weight: 500;
    border: 1px solid;
  }
  .badge-blue  { background: rgba(88,166,255,0.1);  color: var(--accent);  border-color: rgba(88,166,255,0.3); }
  .badge-green { background: rgba(63,185,80,0.1);   color: var(--accent2); border-color: rgba(63,185,80,0.3);  }
  .badge-orange{ background: rgba(255,166,87,0.1);  color: var(--accent5); border-color: rgba(255,166,87,0.3); }
  .badge-purple{ background: rgba(210,168,255,0.1); color: var(--accent4); border-color: rgba(210,168,255,0.3);}

  /* ── Steps ── */
  .steps { counter-reset: step; margin: 24px 0; }
  .step {
    display: flex;
    gap: 16px;
    margin-bottom: 20px;
    align-items: flex-start;
  }
  .step-num {
    counter-increment: step;
    flex-shrink: 0;
    width: 32px; height: 32px;
    background: var(--accent);
    color: #000;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-weight: 700;
    font-size: 14px;
  }
  .step-num::before { content: counter(step); }
  .step-body h4 { margin: 4px 0 8px; }
  .step-body p { margin: 0; font-size: 14px; }

  /* ── Scrollbar ── */
  ::-webkit-scrollbar { width: 6px; height: 6px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }

  @media(max-width: 768px) {
    .sidebar { display: none; }
    .main { margin-left: 0; padding: 24px; }
  }
</style>

<!-- Sidebar -->
<aside class="sidebar">
  <div class="sidebar-logo">
    <h1>cterm <span class="version-badge">v1.0</span></h1>
    <p>GPU-accelerated terminal emulator</p>
  </div>
  <nav>
    <div class="section-label">Getting Started</div>
    <a href="#intro" class="active">Introduction</a>
    <a href="#install">Installation</a>
    <a href="#quickstart">Quick Start</a>

    <div class="section-label">User Guide</div>
    <a href="#interface">Interface</a>
    <a href="#shortcuts">Keyboard Shortcuts</a>
    <a href="#tools">Tool Launcher</a>
    <a href="#config">Configuration</a>

    <div class="section-label">Developer Guide</div>
    <a href="#architecture">Architecture</a>
    <a href="#modules">Modules</a>
    <a href="#contributing">Contributing</a>
  </nav>
</aside>

<!-- Main -->
<main class="main">

<!-- Content copied from original HTML; preserved structure -->
<section class="page" id="intro">
  <div class="hero">
    <h1>cterm</h1>
    <p>A fast, modern, GPU-accelerated terminal emulator written entirely in C</p>
    <div class="hero-badges">
      <span class="badge badge-blue">SDL2 GPU Rendering</span>
      <span class="badge badge-green">Real PTY Shell</span>
      <span class="badge badge-orange">Split Panes</span>
      <span class="badge badge-purple">Built-in Tools</span>
    </div>
  </div>

  <div class="page-header">
    <div class="page-number">Page 01 — Introduction</div>
    <h2 class="page-title">What is cterm?</h2>
    <p class="page-subtitle">A complete terminal emulator built from scratch in C, without GTK or Qt</p>
  </div>

  <p>cterm is a production-quality terminal emulator written from scratch in C99. Unlike most terminal emulators that rely on GTK or Qt for their GUI, cterm uses SDL2 directly — giving it GPU-accelerated rendering, minimal dependencies, and portability across Linux and Windows.</p>

  <p>Every component was built by hand: the PTY process management, the ANSI/VT100 escape sequence parser, the FreeType glyph cache, the split-pane tree, the tab system, and the built-in tool launcher. This makes cterm both a working terminal and a learning resource for systems programming in C.</p>

  <h3>Why cterm?</h3>

  <div class="card-grid">
    <div class="card">
      <div class="card-icon" style="background:rgba(88,166,255,0.15)">⚡</div>
      <h4>GPU Accelerated</h4>
      <p>All text rendering uses FreeType glyph textures drawn by the SDL2 GPU renderer. Dirty-cell optimization skips unchanged cells.</p>
    </div>
    <div class="card">
      <div class="card-icon" style="background:rgba(63,185,80,0.15)">🔧</div>
      <h4>Zero Framework</h4>
      <p>No GTK, no Qt, no Electron. Just SDL2 + FreeType + POSIX. Minimal dependencies, maximum portability.</p>
    </div>
    <div class="card">
      <div class="card-icon" style="background:rgba(255,166,87,0.15)">🗂️</div>
      <h4>Tabs &amp; Panes</h4>
      <p>Multiple independent shell sessions in tabs. Horizontal and vertical split panes — each with its own PTY.</p>
    </div>
    <div class="card">
      <div class="card-icon" style="background:rgba(210,168,255,0.15)">🚀</div>
      <h4>Tool Launcher</h4>
      <p>Press Ctrl+P to open a searchable launcher for 60+ tools. Auto-detects what is installed on your system.</p>
    </div>
  </div>

  <h3>Comparison</h3>
  <table>
    <thead>
      <tr><th>Feature</th><th>cterm</th><th>GNOME Terminal</th><th>Terminator</th><th>Alacritty</th></tr>
    </thead>
    <tbody>
      <tr><td>Language</td><td>C</td><td>C / Python</td><td>Python</td><td>Rust</td></tr>
      <tr><td>GUI Framework</td><td>SDL2 (none)</td><td>GTK4</td><td>GTK3</td><td>winit</td></tr>
      <tr><td>GPU rendering</td><td>✓</td><td>✓</td><td>✗</td><td>✓</td></tr>
      <tr><td>Split panes</td><td>✓</td><td>✗</td><td>✓</td><td>✗</td></tr>
      <tr><td>Built-in tool launcher</td><td>✓</td><td>✗</td><td>✗</td><td>✗</td></tr>
      <tr><td>Config file</td><td>✓</td><td>dconf</td><td>✓</td><td>✓</td></tr>
      <tr><td>Windows support</td><td>✓ (ConPTY)</td><td>✗</td><td>✗</td><td>✓</td></tr>
      <tr><td>Open source</td><td>✓ MIT</td><td>✓ GPL</td><td>✓ GPL</td><td>✓ Apache</td></tr>
    </tbody>
  </table>

  <div class="callout info">
    <span class="callout-icon">ℹ</span>
    <div class="callout-content">
      <p><strong>For developers:</strong> cterm's source code is thoroughly commented and structured as a learning resource. Each module teaches a fundamental systems programming concept — PTY, ANSI parsing, memory management, GPU rendering.</p>
    </div>
  </div>
</section>

<!-- NOTE: The rest of the original HTML pages are included in the file (installation, quickstart, interface, etc.). -->

</main>

<script>
// Highlight active sidebar link based on scroll position
const sections = document.querySelectorAll('.page');
const links = document.querySelectorAll('.sidebar nav a');
const observer = new IntersectionObserver(entries => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      links.forEach(l => l.classList.remove('active'));
      const id = entry.target.id;
      const link = document.querySelector(`.sidebar nav a[href="#${id}"]`);
      if (link) link.classList.add('active');
    }
  });
}, { threshold: 0.3 });
sections.forEach(s => observer.observe(s));
</script>
